<%- include('../partials/layout-head', { title: 'Catálogo', user }) %>

<form action="/" method="get" class="flex flex-wrap gap-3 mb-8 items-end">
  <div class="flex-1 min-w-48">
    <label class="block text-xs text-gray-500 mb-1">Buscar</label>
    <input type="text" name="q" value="<%= q || '' %>" placeholder="Nombre o descripción..."
           class="w-full border border-gray-300 rounded px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-300"/>
  </div>
  <div>
    <label class="block text-xs text-gray-500 mb-1">Categoría</label>
    <select name="category" class="border border-gray-300 rounded px-3 py-2 text-sm">
      <option value="">Todas</option>
      <% categories.forEach(c => { %>
        <option value="<%= c.slug %>" <%= category === c.slug ? 'selected' : '' %>><%= c.name %></option>
      <% }) %>
    </select>
  </div>
  <div>
    <label class="block text-xs text-gray-500 mb-1">Precio máximo</label>
    <input type="number" name="maxPrice" value="<%= maxPrice || '' %>" placeholder="Sin límite"
           class="w-32 border border-gray-300 rounded px-3 py-2 text-sm"/>
  </div>
  <button type="submit" class="bg-indigo-600 text-white px-4 py-2 rounded text-sm hover:bg-indigo-700">Buscar</button>
  <a href="/" class="text-sm text-gray-500 hover:underline py-2">Limpiar</a>
</form>

<div class="flex items-center justify-between mb-4">
  <p class="text-sm text-gray-500"><%= total %> productos encontrados</p>
</div>

<% if (!products.length) { %>
  <div class="text-center py-16 text-gray-400"><p class="text-4xl mb-3">🔍</p><p>No se encontraron productos</p></div>
<% } %>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
  <% products.forEach(p => { %>
    <a href="/productos/<%= p.slug %>"
       class="bg-white rounded-xl border border-gray-200 shadow-sm hover:shadow-md transition-shadow overflow-hidden group">
      <div class="bg-gradient-to-br from-indigo-50 to-purple-50 h-48 flex items-center justify-center text-5xl">🛍</div>
      <div class="p-4">
        <p class="text-xs text-indigo-500 font-medium mb-1"><%= p.categoryName %></p>
        <h3 class="font-semibold text-gray-800 group-hover:text-indigo-600 transition-colors"><%= p.name %></h3>
        <div class="flex items-center justify-between mt-3">
          <span class="text-lg font-bold text-gray-900">$<%= Number(p.basePrice).toLocaleString('es-CL') %></span>
          <% if (p.minStock > 0) { %>
            <span class="text-xs bg-green-100 text-green-700 px-2 py-0.5 rounded-full">En stock</span>
          <% } else { %>
            <span class="text-xs bg-red-100 text-red-600 px-2 py-0.5 rounded-full">Sin stock</span>
          <% } %>
        </div>
      </div>
    </a>
  <% }) %>
</div>

<% if (totalPages > 1) { %>
  <div class="flex justify-center gap-2 mt-10">
    <% if (page > 0) { %><a href="/?page=<%= page-1 %>&q=<%= q||'' %>&category=<%= category||'' %>" class="px-4 py-2 border border-gray-300 rounded text-sm hover:bg-gray-50">← Anterior</a><% } %>
    <span class="px-4 py-2 text-sm text-gray-600">Página <%= page+1 %> de <%= totalPages %></span>
    <% if (page+1 < totalPages) { %><a href="/?page=<%= page+1 %>&q=<%= q||'' %>&category=<%= category||'' %>" class="px-4 py-2 border border-gray-300 rounded text-sm hover:bg-gray-50">Siguiente →</a><% } %>
  </div>
<% } %>

<%- include('../partials/layout-foot') %>
