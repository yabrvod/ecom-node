<%- include('../partials/layout-head', { title: product.name, user }) %>

<nav class="text-sm text-gray-500 mb-6">
  <a href="/" class="hover:text-indigo-600">Catálogo</a> ›
  <a href="/?category=<%= product.categorySlug %>" class="hover:text-indigo-600"><%= product.categoryName %></a> ›
  <span class="text-gray-800"><%= product.name %></span>
</nav>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
  <div class="bg-gradient-to-br from-indigo-50 to-purple-50 rounded-2xl h-96 flex items-center justify-center text-8xl">🛍</div>
  <div>
    <p class="text-sm text-indigo-500 font-medium mb-1"><%= product.categoryName %></p>
    <h1 class="text-3xl font-bold text-gray-900 mb-3"><%= product.name %></h1>
    <p class="text-gray-600 mb-6"><%= product.description %></p>

    <h3 class="font-semibold text-gray-700 mb-3">Selecciona una variante:</h3>
    <div class="grid grid-cols-2 gap-3 mb-6">
      <% product.variants.forEach(v => { %>
        <form action="/carrito/agregar" method="post">
          <input type="hidden" name="_csrf" value="<%= csrf %>"/>
          <input type="hidden" name="variantId" value="<%= v.id %>"/>
          <input type="hidden" name="quantity" value="1"/>
          <button type="submit"
                  <%= v.stock <= 0 ? 'disabled' : '' %>
                  class="w-full text-left border-2 rounded-lg p-3 transition-colors
                    <%= v.stock > 0 ? 'border-gray-200 hover:border-indigo-500 hover:bg-indigo-50 cursor-pointer' : 'border-gray-100 bg-gray-50 opacity-50 cursor-not-allowed' %>">
            <p class="font-medium text-sm text-gray-800"><%= v.name %></p>
            <p class="text-indigo-600 font-bold text-sm">$<%= Number(v.price).toLocaleString('es-CL') %></p>
            <p class="text-xs mt-1 <%= v.stock > 0 ? 'text-green-600' : 'text-red-400' %>">
              <%= v.stock > 0 ? v.stock + ' disponibles' : 'Sin stock' %>
            </p>
          </button>
        </form>
      <% }) %>
    </div>
  </div>
</div>

<%- include('../partials/layout-foot') %>
