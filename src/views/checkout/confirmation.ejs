<%- include('../partials/layout-head', { title: 'Pedido confirmado', user }) %>
<div class="max-w-2xl mx-auto">
  <div class="text-center mb-8">
    <div class="text-6xl mb-4">✅</div>
    <h1 class="text-2xl font-bold text-gray-900">¡Pedido confirmado!</h1>
    <p class="text-gray-500 mt-2">Orden #<%= order.id %></p>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl p-6 mb-6">
    <h2 class="font-bold text-gray-800 mb-4">Detalle del pedido</h2>
    <% order.items.forEach(item => { %>
      <div class="flex justify-between items-center py-3 border-b border-gray-100 last:border-0">
        <div>
          <p class="font-medium text-sm"><%= item.product_name %></p>
          <p class="text-xs text-gray-500"><%= item.variant_name %> × <%= item.quantity %></p>
        </div>
        <p class="font-semibold text-sm">$<%= (Number(item.unit_price)*item.quantity).toLocaleString('es-CL') %></p>
      </div>
    <% }) %>
    <div class="flex justify-between items-center pt-4 font-bold text-lg">
      <span>Total</span>
      <span class="text-indigo-600">$<%= Number(order.total).toLocaleString('es-CL') %></span>
    </div>
  </div>
  <div class="bg-green-50 border border-green-200 rounded-xl p-4 text-center text-sm text-green-700 mb-6">
    Pago aprobado · <%= order.payment?.method || 'SIMULATED' %>
  </div>
  <div class="text-center">
    <a href="/" class="bg-indigo-600 text-white px-6 py-3 rounded-lg hover:bg-indigo-700">Seguir comprando</a>
  </div>
</div>
<%- include('../partials/layout-foot') %>
